{
  "name": "ao3-helper",
  "version": "1.2.0",
  "description": "Enhanced AO3 experience with modern UI and features",
  "scripts": {
    "build": "vite build && node scripts/split-userscript.mjs",
    "dev": "vite build --watch",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node tests/e2e/menu-boot.mjs && node tests/e2e/route-loading.mjs",
    "typecheck": "tsc --noEmit",
    "docs": "echo \"📖 Documentation disponible dans le dossier docs/\"",
    "help": "echo \"Commands: npm run build (userscript Vite), npm run dev (build watch), npm test (vitest), npm run docs (documentation)\""
  },
  "keywords": [
    "ao3",
    "archive-of-our-own",
    "userscript",
    "tampermonkey"
  ],
  "author": "AO3 Helper Team",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.6.1",
    "playwright": "^1.61.1",
    "prettier": "3.8.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-monkey": "^8.0.6",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "."
  },
  "files": [
    "*.js",
    "lib/",
    "dist/",
    "docs/"
  ]
}
